# yamllint config. Extends the default ruleset with relaxations that fit
# GitHub Actions workflows and typical project YAML. Enforced locally via the
# pre-commit `yamllint` hook and in CI.
---
extends: default

rules:
  # 80 is too tight for workflows; 120 is the enforced limit (error).
  line-length:
    max: 120
    # The bootstrap provenance marker (#213) stamps a single machine-generated
    # comment line (template path + plugin version + sha256) onto these tracked
    # files. It exceeds 120 and cannot wrap, so exempt these files from
    # line-length only — every other yamllint rule still applies to them.
    ignore: |
      .github/workflows/*.yml
      trivy.yaml
  # GitHub Actions' `on:` key is valid; don't flag it as a "truthy" value.
  truthy:
    allowed-values: ['true', 'false', 'on', 'off']
  # Workflow / config files conventionally omit the `---` document start.
  document-start: disable
  # Cosmetic; conflicts with common section-marker comment conventions. Off.
  comments-indentation: disable
