# EditorConfig — cross-editor whitespace and encoding consistency.
# Honored by VS Code, JetBrains, Vim, Emacs, Sublime, and most others
# (some via a plugin). https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# 2-space-indent languages
[*.{js,jsx,ts,tsx,json,jsonc,yaml,yml,html,css,scss,vue,svelte}]
indent_size = 2

# Go uses tabs by convention
[*.go]
indent_style = tab
indent_size = 4

# Makefiles require literal tabs — non-negotiable
[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab
indent_size = 4

# Markdown: don't trim trailing whitespace because two trailing spaces
# encode a line break in the rendered output
[*.md]
trim_trailing_whitespace = false

# Patches and diffs must preserve their exact bytes
[*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false
